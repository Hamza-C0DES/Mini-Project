// Prisma schema — define your database models here.
//
// The models are yours to design (see the project spec for the game rules).
// After adding or changing a model, run:  yarn prisma:migrate
// Prisma 7 note: the connection URL lives in `prisma.config.ts`, not here.
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Working On Schema //
model game{
  id Int @id @default(autoincrement())
  username String 
  roomcode String
  answer String
}

// TODO: add your models below (for example, a Game and its Answers).

model Game {
  id Int  @id @default(autoincrement())
  roomcode String
  celebrity String
  celebrities Answers[]
}

model Answers {
  id Int @id @default(autoincrement())
  celebrity String
  username String
  gameId Int
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([gameId, celebrity])
}
