generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Working On Schema //
model game{
  id Int @id @default(autoincrement())
  username String 
  roomcode String
  answer String
}

